{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "lib": ["es2022"]
  },
  "include": ["src/**/*"],
  "exclude": ["scripts", "node_modules", "dist"]
}